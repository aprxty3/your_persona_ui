# BE API base URL (controller-api). Local dev: the API runs on :8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Cloudflare Turnstile SITE key (not a secret!). The value below is Cloudflare's
# official test sitekey that ALWAYS passes — used in dev so the FE flow is
# identical to production (Tech Doc §5.3). Production: replace with the real sitekey.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# PostHog (Tech Doc §8) — leave empty in dev if you don't want to send events.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
